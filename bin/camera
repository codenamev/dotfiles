#!/bin/bash

touch $HOME/.camerastate
touch $HOME/.cameralog
echo "0" > $HOME/.camerastate
device=''
event=''
process=0
activeCount=0

function activateonair() {
  echo "Activate On Air" >> $HOME/.cameralog
  echo "1" > $HOME/.camerastate
  /usr/bin/shortcuts run 'Activate On Air' &
}

function deactivateonair() {
  echo "De-activate On Air" >> $HOME/.cameralog
  echo "0" > $HOME/.camerastate
  /usr/bin/shortcuts run 'De-activate On Air' &
}

function updatecamerastate() {
  globalcamerastate=$(cat $HOME/.camerastate)
}

while test $# -gt 0; do
  case "$1" in
    -h|--help)
      echo "camera - run shortcut on camera activity"
      echo " "
      echo "camera [options]"
      echo " "
      echo "options:"
      echo "-h, --help show this help message"
      echo "-d, --device=<camera|microphone>"
      echo "-e, --event=<on|off>"
      echo "-p, --process=<pid> activation process id"
      echo "-a, --activeCount=<0..n> number of devices still active"
      exit 0
      ;;
    -d|-device|--device)
      shift
      if test $# -gt 0; then
        echo "Device: $1"
        device="$1"
      fi
      shift
      ;;
    -e|-event|--event)
      shift
      if test $# -gt 0; then
        echo "Event: $1"
        event="$1"
      fi
      shift
      ;;
    -p|-process|--process)
      shift
      if test $# -gt 0; then
        echo "Process: $1"
        process=$1
      fi
      shift
      ;;
    -a|-activeCount|--activeCount)
      shift
      if test $# -gt 0; then
        echo "activeCount: $1"
        activeCount=$1
      fi
      shift
      ;;
    *)
      break
      ;;
  esac
done

echo "Detected $device state changed to $event (p: $process, a: $activeCount)"

if [[ "$device" =~ (camera) && "$event" =~ (on|On) ]]; then
  activateonair
elif [[ "$device" =~ (camera) && "$event" =~ (off|Off) ]]; then
  deactivateonair
fi

