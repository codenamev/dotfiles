#!/usr/bin/env bash

command_exists() {
  command -v foo >/dev/null 2>&1;
}

if [ "$1" = "" ]; then
  echo "usage: global-gem install gem_name";
  exit 1;
fi

# chruby
# load chruby if available (Apple Silicon and Intel Homebrew paths)
for CHRUBY_COMMAND in \
  /opt/homebrew/opt/chruby/share/chruby/chruby.sh \
  /usr/local/share/chruby/chruby.sh; do
  [ -f "$CHRUBY_COMMAND" ] && break
done
if [ -f $CHRUBY_COMMAND ]; then
  source $CHRUBY_COMMAND
else
  echo "WTF"
fi

if [ -n "chruby" ]; then
  echo "Installing for chruby: $(command -v chruby)";
  for v in $(chruby); do
    if [ "$v" != "*" ]; then
      echo "----> Running 'gem $@' for $v";
      chruby $v;
      gem $@;
    fi
  done
  exit 0;
fi

# rbenv
if command_exists rbenv; then
  eval "$(rbenv init -)"
  for v in $(rbenv versions --bare); do
    echo "-----> Running 'gem $@' for $v";
    rbenv shell $v;
    gem $@;
  done
fi

echo "No ruby version managers found"
exit 1
