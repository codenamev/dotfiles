[init]
  defaultBranch = main
  templatedir = ~/.git_template
[rerere]
  enabled = 1
[push]
  default = current
[color]
  ui = auto
[alias]
  aa = add --all
  ap = add --patch
  br = branch
  branches = for-each-ref --sort=-committerdate --format=\"%(color:blue)%(authordate:relative)\t%(color:red)%(authorname)\t%(color:white)%(color:bold)%(refname:short)\" refs/remotes
  ci = commit -v
  co = checkout
  pf = push --force-with-lease
  st = status -sb
[core]
  excludesfile = ~/.gitignore
  attributesfile = ~/.gitattributes
	autocrlf = input
[commit]
  template = ~/.gitmessage
	gpgsign = true
[fetch]
  prune = true
[rebase]
  autosquash = true
[diff]
  colorMoved = zebra
[merge]
  ff = only
[user]
  name = Valentino Stoll
  email = v@codenamev.com
	signingkey = /Users/valentino.stoll/.ssh/id_ed25519.pub
[include]
  path = ~/.gitconfig.local
[gpg]
	format = ssh
[safe]
	directory = /workspace
[url "git@github.com:"]
	insteadOf = https://github.com/
